{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "bun-types"]
  },
  "include": ["scripts/**/*.ts", "tests/conformance.ts", "tests/bench-perf.ts", "tests/bench-fast-profile.ts"]
}
